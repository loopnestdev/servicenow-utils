# THIS IS READ BY THE STANDALONE DAEMON AND EMBEDDED SERVERS
[server]

# THIS IS ONLY FOR THE MYSQLD STANDALONE DAEMON
[mysqld]
bind-address                    = *
port                            = %%MARIADB_PORT%%
datadir                         = %%MARIADB_DATADIR%%
tmpdir                          = %%MARIADB_TEMPDIR%%
socket                          = /var/lib/mysql/mysql.sock
sql-mode                        = NO_ENGINE_SUBSTITUTION
key_buffer_size                 = 128M
max_allowed_packet              = 32M
tmp_table_size                  = 64M
max_heap_table_size             = 64M
myisam_sort_buffer_size         = 256k
open-files-limit                = 32768
net_write_timeout               = 900
net_read_timeout                = 900
lock_wait_timeout               = 14400
server_id                       = 1
sync_binlog                     = 1
log-bin                         = %%MARIADB_BINLOGDIR%%/mariadb-binlog
relay-log                       = %%MARIADB_BINLOGDIR%%/mariadb-relay
relay-log-index                 = %%MARIADB_BINLOGDIR%%/mariadb-relay.index
relay-log-info-file             = %%MARIADB_BINLOGDIR%%/mariadb-relay.info
expire_logs_days                = 7
log-slave-updates               = 1
read-only                       = 0
binlog_cache_size               = 1M
slave_compressed_protocol       = 1
log-bin-trust-function-creators = 1
default-storage-engine          = innodb
character-set-server            = utf8
innodb_default_row_format       = dynamic
innodb_strict_mode              = off
query_cache_size                = 0
query_cache_type                = 0
eq_range_index_dive_limit       = 0
innodb_use_native_aio           = 1
innodb_stats_persistent         = 1
innodb_adaptive_flushing        = 1
innodb_checksum_algorithm       = crc32
innodb_log_buffer_size          = 16M
innodb_flush_log_at_trx_commit  = 0
innodb_stats_on_metadata        = 0
innodb_flush_method             = O_DIRECT
innodb_lock_wait_timeout        = 50
innodb_flush_neighbors          = 1
innodb_max_dirty_pages_pct      = 75
innodb_file_per_table           = 1
innodb_print_all_deadlocks      = on
innodb_autoinc_lock_mode        = 1
performance_schema              = on
innodb_data_file_path           = ibdata1:10M:autoextend
secure-auth                     = on
local-infile                    = off
symbolic-links                  = 0
innodb_monitor_disable          = ALL
long_query_time                 = 1
log_queries_not_using_indexes   = 0
log_warnings                    = 2
max_connect_errors              = 1000
innodb_buffer_pool_size         = %%INNODB_BUFFER_POOL_SIZE%%
innodb_log_file_size            = 32G
innodb_io_capacity              = 65536
innodb_open_files               = 8000
innodb_page_size                = 64k
table_open_cache                = 8000
table_definition_cache          = 12000
sort_buffer_size                = 1M
max_connections                 = 4000
innodb_sync_spin_loops          = 20
innodb_read_io_threads          = 10
innodb_write_io_threads         = 8
innodb_purge_threads            = 4
innodb_purge_batch_size         = 300
innodb_max_purge_lag            = 5000000
slave_parallel_threads          = 16
slave_parallel_mode             = conservative
gtid_strict_mode                = 1
log_slave_updates               = 1

# SSL CONFIGURATION
ssl-ca                          = %%SSL_CACERT%%
ssl-cert                        = %%MARIADB_SSLDIR%%/host.crt
ssl-key                         = %%MARIADB_SSLDIR%%/host.key
ssl-cipher                      = AESGCM:!aNULL:!eNULL
tls_version                     = TLSv1.3

# AUDIT CONFIGURATION
plugin_load_add                 = server_audit
server_audit_logging            = on
server_audit_events             = CONNECT,QUERY_DDL,QUERY_DML,QUERY_DCL
server_audit_output_type        = file
server_audit_file_path          = %%MARIADB_LOGDIR%%/server-audit.log
server_audit_file_rotate_size   = 128M
server_audit_file_rotations     = 8

# SLOW QUERIES CONFIGURATION
slow_query_log                  = on
slow_query_log_file             = %%MARIADB_LOGDIR%%/server-slow.log

[mysqld_safe]
log-error                       = %%MARIADB_LOGDIR%%/mysqld.log

[mysqldump]
quick
max_allowed_packet              = 32M

[mysql]
no-auto-rehash

# THIS IS ONLY FOR EMBEDDED SERVER
[embedded]
